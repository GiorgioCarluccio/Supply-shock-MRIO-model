# Python caches and test artifacts
__pycache__/
*.pyc
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local environments and secrets
.venv/
venv/
env/
.env
.env.*

# Build and packaging outputs
build/
dist/
*.egg-info/
.eggs/

# Notebook and editor noise
.ipynb_checkpoints/
.vscode/*
!.vscode/settings.json
.idea/
tempCodeRunnerFile.py

# Operating system files
.DS_Store
Thumbs.db

# Large climate, raster, and geospatial data files
*.nc
*.nc4
*.cdf
*.grib
*.grb
*.grb2
*.tif
*.tiff
*.h5
*.hdf
*.hdf5
*.zarr/
*.parquet
*.npy
*.npz
*.feather
*.gpkg
*.shp
*.shx
*.dbf
*.prj
*.cpg

# Large compressed data archives
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.rar

# Local data products.
# Keep directory placeholders, but do not commit raw, interim, or generated data.
data/raw/*
data/interim/
data/processed/
!data/interim/
!data/processed/
data/interim/*
data/processed/*
data/**/*.json

!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

.databricks
